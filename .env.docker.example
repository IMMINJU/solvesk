# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=solvesk

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (optional — SMTP)
# Brevo (free, 300/day): smtp-relay.brevo.com / 587
# Gmail: smtp.gmail.com / 587 (app password required)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password-or-api-key
# EMAIL_FROM=Solvesk <noreply@solvesk.io>
