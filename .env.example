# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solvesk

# Docker Compose uses these to create the database:
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=solvesk
# POSTGRES_PORT=5432

# DATABASE_SSL=true         # Enable SSL for cloud-hosted databases (Neon, Supabase, etc.)

# ── NextAuth ──────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── App URL (used in email links) ─────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Environment ──────────────────────────────────
# NODE_ENV=production
# LOG_LEVEL=info          # debug | info | warn | error

# ── Email (optional) ─────────────────────────────
# If not set, emails are logged to console instead of sent.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Solvesk <noreply@example.com>
